@{
    ViewData["Title"] = "Nova Receita";
}

@model CraftworkManager.Models.Finance.Transaction

<form method="post">

    <h1>Nova Receita</h1>

    <div class="mt-3">
        <label class="form-label">Descrição</label>
        <input type="text" class="form-control" asp-for="Description" />
    </div>

    <div class="mt-3">
        <label class="form-label">Data</label>
        <input type="text" class="form-control" asp-for="Date" />
    </div>

    <label class="form-label">Vincular a um envio:</label>
    @if(Model.ShipmentId.HasValue)
        {
        
        <select id="shipmentSelect"
                asp-for="ShipmentId"
                asp-items="ViewBag.PendingShipments">
            <option value="">Selecione</option>
        </select>
        }
        else
        {
        <select id="shipmentSelect"
                asp-for="ShipmentId"
                asp-items="ViewBag.PendingShipments">
            <option value="">Selecione</option>
        </select>
        }
        <span>Vincular uma receita a um envio apenas atribui que o pedido/envio foi pago e o retira das pendências de receita. <strong>É possível não atribuir um envio.</strong></span>
        @if (Model.ShipmentId.HasValue)
        {
        <span>A receita, considerando o valor dos produtos, os descontos, acréscimos, taxas e frete no pedido e no envio, deveria ser de R$<strong>@Model.Shipment.getTotalPrice()</strong></span>
        }
    <div class="mt-3">
        <label class="form-label">Valor</label>
        <input type="number" step="0.01" class="form-control" asp-for="Amount" />
    </div>

    <div class="mt-3">
        <input type="checkbox" class="form-check-input" id="NF" asp-for="Pending" />
        <label for="NF" class="form-label">Receita Pendente</label>
    </div>

    

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Confirmar Receita</button>
    </div>

</form>