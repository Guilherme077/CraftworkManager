@{
    ViewData["Title"] = "Nova Despesa";
}

@model CraftworkManager.Models.Finance.Transaction

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h1 class="card-title mb-0">
                        <i class="bi bi-dash-circle me-2"></i>Nova Despesa
                    </h1>
                </div>

                <div class="card-body">
                    <form method="post" asp-controller="Finance" asp-action="AddTransaction">
                        <input type="hidden" asp-for="Type" />
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Descrição</label>
                                <input type="text" class="form-control" asp-for="Description" placeholder="Digite a descrição da despesa" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Data</label>
                                <input type="text" class="form-control" asp-for="Date" placeholder="dd/mm/yyyy" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Valor <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control" asp-for="Amount" placeholder="0,00" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="NF" asp-for="Pending" />
                                <label for="NF" class="form-check-label">
                                    Marcar como despesa pendente
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="bi bi-check-lg me-2"></i>Confirmar Despesa
                            </button>
                            <a href="/Finance/Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>