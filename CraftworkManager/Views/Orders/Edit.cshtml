*@
@{
}

@model CraftworkManager.Models.Order

@if (Model is null)
{
    <p class="alert-warning">Pedido não encontrado. O pedido pode ter sido excluido ou você não possui acesso.</p>
}
else
{

    <h1>Pedido</h1>

    

    <h3>Itens do Pedido</h3>

    <a asp-controller="Orders" asp-action="AddItem" class="btn btn-primary">Adicionar Item</a>

    <table class="table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Preço de Venda</th>
                <th>Quantidade</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var orderItem in Model.OrderItems)
            {
                <tr>
                    <td>@orderItem.BaseProduct.Name</td>
                    <td>@orderItem.Description</td>
                    <td>@orderItem.Price</td>
                    <td>@orderItem.Quantity</td>
                    <td><a class="btn btn-primary" asp-controller="Orders" asp-action="EditItem" asp-route-id="@orderItem.Id">Editar</a></td>
                </tr>
            }
        </tbody>
    </table>
    <form method="post">

        <h3>Detalhes da Compra</h3>

        <div class="mt-3">
            <label class="form-label">Cliente</label>
            <input type="text" class="form-control" asp-for="ClientName" />
        </div>

        <div class="mt-3">
            <label class="form-label">Endereço do Cliente</label>
            <input type="text" class="form-control" asp-for="ClientAddress" />
        </div>

        <div class="mt-3">
            <label class="form-label">Forma de Pagamento</label>
            <select asp-for="PaymentWay"
                    asp-items="ViewBag.PaymentList"
                    class="form-control">
            </select>
        </div>

        <div class="mt-3">
            <label class="form-label">URL</label>
            <input type="text" class="form-control" asp-for="Url" />
        </div>

        <div class="mt-3">
            <input type="checkbox" class="form-check-input" id="NF" asp-for="WithNF" />
            <label for="NF" class="form-label">Emissão de Nota Fiscal</label>
        </div>


        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Salvar Detalhes</button>
        </div>

    </form>
}

