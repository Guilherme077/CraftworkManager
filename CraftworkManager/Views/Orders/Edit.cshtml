@using System.ComponentModel.DataAnnotations
@using CraftworkManager.Models.LogsModels
@{
}

@model CraftworkManager.Models.Order

@if (Model is null)
{
    <div class="container mt-4">
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Pedido não encontrado. O pedido pode ter sido excluído ou você não possui acesso.
        </div>
    </div>
}
else
{
    var statusName = Model.Status.GetAttribute<DisplayAttribute>();
    var statusBadgeClass = Model.Status switch
    {
        OrderStatus.Pending => "bg-info",
        OrderStatus.InProduction => "bg-warning",
        OrderStatus.Paused => "bg-secondary",
        OrderStatus.ReadyToShip => "bg-success",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Cancelled => "bg-danger",
        _ => "bg-dark"
    };

    <div class="container-fluid mt-4">
        <div class="row mb-4">
            <div class="col-md-6">
                <h1 class="mb-3">
                    <i class="bi bi-pencil-square me-2"></i>Edição do Pedido
                </h1>
                <span class="badge @statusBadgeClass fs-6">
                    <i class="bi bi-info-circle me-2"></i>@statusName.Name
                </span>
            </div>
            <div class="col-md-6 d-flex align-items-center justify-content-md-end mt-3 mt-md-0">
                <a href="/Orders/List" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Voltar
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-box me-2"></i>Itens do Pedido
                        </h5>
                    </div>
                    <div class="card-body">
                        <a asp-controller="Orders" asp-action="AddItem" asp-route-orderId="@Model.Id" class="btn btn-success btn-sm mb-3">
                            <i class="bi bi-plus-circle me-1"></i>Adicionar Item
                        </a>

                        @if (Model.OrderItems.Count == 0)
                        {
                            <div class="alert alert-info" role="alert">
                                <i class="bi bi-info-circle me-2"></i>
                                Nenhum item adicionado ao pedido ainda.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Produto</th>
                                            <th>Descrição</th>
                                            <th class="text-end">Preço Unit.</th>
                                            <th class="text-center">Qtd.</th>
                                            <th class="text-end">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var orderItem in Model.OrderItems)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@orderItem.BaseProduct.Name</strong>
                                                </td>
                                                <td>
                                                    <small>@orderItem.Description</small>
                                                </td>
                                                <td class="text-end">
                                                    R$ <strong>@orderItem.Price.ToString()</strong>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-primary">@orderItem.Quantity</span>
                                                </td>
                                                <td class="text-end">
                                                    <a class="btn btn-sm btn-warning" asp-controller="Orders" asp-action="EditItem" asp-route-id="@orderItem.Id" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a class="btn btn-sm btn-danger" asp-controller="Orders" asp-action="DeleteItem" asp-route-id="@orderItem.Id" title="Remover">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="card-title mb-0">Linha do Tempo</h5>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            @foreach(var log in ViewBag.StatusHistory)
                            {
                                var bgColor = log.ModificationType switch
                                {
                                    ModificationType.StatusChanged => log.Status switch
                                    {
                                        OrderStatus.Pending => "info",
                                        OrderStatus.InProduction => "warning",
                                        OrderStatus.Paused => "secondary",
                                        OrderStatus.ReadyToShip => "success",
                                        OrderStatus.Shipped => "primary",
                                        OrderStatus.Cancelled => "danger",
                                        _ => "dark"
                                    },
                                    ModificationType.Created => "info",
                                    ModificationType.Deleted => "danger",
                                    _ => "info"
                                };
                                var statusIcon = log.ModificationType switch
                                {
                                    ModificationType.StatusChanged => log.Status switch
                                    {
                                        OrderStatus.Pending => "clock",
                                        OrderStatus.InProduction => "hammer",
                                        OrderStatus.Paused => "pause-circle",
                                        OrderStatus.ReadyToShip => "check-circle",
                                        OrderStatus.Shipped => "truck",
                                        OrderStatus.Cancelled => "x-circle",
                                        _ => "question-circle"
                                    },
                                    ModificationType.Created => "plus-circle",
                                    ModificationType.Deleted => "trash",
                                    _ => "question-circle"
                                };
                                var description = log.ModificationType == ModificationType.StatusChanged ? log.Status.ToString() : log.ModificationType.ToString();
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-@bgColor text-white">
                                        <i class="bi bi-@statusIcon"></i>
                                    </div>
                                    <div class="timeline-content">
                                        <span>@description</span>
                                        <span class="ms-2 text-muted">@log.ChangedOn.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>    
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <form method="post">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-sticky me-2"></i>Notas do Pedido
                            </h5>
                        </div>
                        <div class="card-body">
                            <textarea id="notes" name="notes" rows="6" class="form-control" placeholder="Digite notas do pedido aqui..." asp-for="Notes"></textarea>
                            <small class="text-muted d-block mt-2">Use este campo para adicionar informações importantes sobre o pedido, instruções especiais ou observações gerais.</small>

                        </div>
                    </div>
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-info text-white">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-file-text me-2"></i>Detalhes da Compra
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Cliente</label>
                                <input type="text" class="form-control" asp-for="ClientName" placeholder="Nome do cliente" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Prazo</label>
                                <input type="date" class="form-control" asp-for="DeadlineOn" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">URL</label>
                                <input type="text" class="form-control" asp-for="Url" placeholder="https://exemplo.com" />
                            </div>

                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="NF" asp-for="WithNF" />
                                <label for="NF" class="form-check-label">
                                    Emissão de Nota Fiscal
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-cash-coin me-2"></i>Informações Financeiras
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3 p-3 bg-light rounded">
                                <small class="text-muted d-block">Subtotal (Itens)</small>
                                <h6 class="mb-0">R$ <strong>@Model.getOrderItemsTotalPrice().ToString("F2")</strong></h6>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Forma de Pagamento</label>
                                <select asp-for="PaymentWay"
                                        asp-items="ViewBag.PaymentList"
                                        class="form-select">
                                </select>
                            </div>

                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label fw-bold">Desconto</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R$</span>
                                        <input type="number" class="form-control" step="0.01" id="discountInput" asp-for="Discount" placeholder="0,00" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold">Aumento</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R$</span>
                                        <input type="number" class="form-control" step="0.01" id="raiseInput" asp-for="Raise" placeholder="0,00" />
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Taxas</label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input type="number" class="form-control" step="0.01" id="taxesInput" asp-for="Taxes" placeholder="0,00" />
                                </div>
                                <small class="text-muted">Valor adicionado ao preço final</small>
                            </div>

                            <div class="p-3 bg-primary text-white rounded mb-3">
                                <small class="d-block opacity-75">Preço Final de Venda Registrado</small>
                                <h5 class="mb-0">R$ <strong>@Model.getTotalPrice().ToString("F2")</strong></h5>
                            </div>
                            <small class="text-muted">Salve para atualizar o valor final.</small>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4 bg-light">
                        <div class="card-body">
                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-calendar-event me-1"></i>
                                <strong>Criado em:</strong> @Model.CreatedOn.ToString("dd/MM/yyyy HH:mm")
                            </small>
                            <small class="text-muted d-block">
                                <i class="bi bi-pencil me-1"></i>
                                <strong>Última atualização:</strong> @(Model.LastUpdateOn.HasValue ? Model.LastUpdateOn.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                            </small>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-lg me-2"></i>Salvar Alterações
                        </button>
                        <a href="/Orders/List" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-2"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

