@model CraftworkManager.Models.AddItemViewModel

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h1 class="card-title mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Adicionar Item
                    </h1>
                </div>

                <div class="card-body">
                    <form method="post" asp-action="AddItem">
                        <input type="hidden" asp-for="OrderId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Produto <span class="text-danger">*</span></label>
                            <select id="productSelect"
                                    asp-for="ProductId"
                                    asp-items="ViewBag.Products"
                                    class="form-select form-select-lg">
                                <option value="">-- Selecione um produto --</option>
                            </select>
                        </div>

                        <div id="itemFields" style="display:none;">
                            <hr class="my-4" />

                            <div class="mb-4">
                                <label class="form-label fw-bold">Descrição</label>
                                <input type="text" class="form-control" id="descriptionInput" asp-for="Description" placeholder="Digite a descrição do item" />
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Preço de Venda</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R$</span>
                                        <input type="number" class="form-control" step="0.01" id="priceInput" asp-for="Price" placeholder="0,00" />
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Custo de Produção</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R$</span>
                                        <input type="number" class="form-control" step="0.01" id="costInput" asp-for="Cost" placeholder="0,00" />
                                    </div>
                                </div>
                            </div>

                            <div class="alert alert-info mb-4" role="alert">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Custo de Produção é um valor para estimativas financeiras e não compõe despesa definitiva. Preço de Venda será utilizado como receita ao final, no momento do registro de receita</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Quantidade <span class="text-danger">*</span></label>
                                <input class="form-control" type="number" min="1" value="1" asp-for="Quantity" placeholder="1" />
                            </div>

                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                    <i class="bi bi-check-lg me-2"></i>Adicionar Item
                                </button>
                                <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                                    <i class="bi bi-arrow-left me-2"></i>Cancelar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const select = document.getElementById("productSelect");
    const fields = document.getElementById("itemFields");
    const priceInput = document.getElementById("priceInput");
    const costInput = document.getElementById("costInput");
    const descriptionInput = document.getElementById("descriptionInput");

    select.addEventListener("change", async function () {
        const productId = this.value;

        if (!productId) {
            fields.style.display = "none";
            return;
        }

        const response = await fetch(`/Products/GetProductInfo?productId=${productId}`);

        if (!response.ok) {
            alert("Erro ao buscar produto");
            return;
        }

        const data = await response.json();

        priceInput.value = (data.price ?? 0).toString().replace(',', '.');
        costInput.value = (data.cost ?? 0).toFixed(2).toString().replace(',', '.');
        descriptionInput.value = data.description ?? '';

        fields.style.display = "block";
    });
</script>