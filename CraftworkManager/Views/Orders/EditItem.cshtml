@model CraftworkManager.Models.OrderItem

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 col-md-10 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h1 class="card-title mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Editar Item
                    </h1>
                </div>

                <div class="card-body">
                    <form method="post" asp-action="EditItem">
                        <div class="alert alert-secondary mb-4" role="alert">
                            <i class="bi bi-box me-2"></i>
                            <strong>Produto:</strong> @Model.BaseProduct.Name
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Descrição</label>
                            <input type="text" class="form-control" id="descriptionInput" asp-for="Description" placeholder="Digite a descrição do item" />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Preço unitário</label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input type="number" class="form-control" step="0.01" id="priceInput" asp-for="Price" placeholder="0,00" />
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Custo de Produção</label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input type="number" class="form-control" step="0.01" id="costInput" asp-for="Cost" placeholder="0,00" />
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mb-4" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            <small>Valores de Preço e Custo são utilizados para as estimativas financeiras e não compõem receita ou despesa definitiva.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Quantidade <span class="text-danger">*</span></label>
                            <input class="form-control" type="number" min="1" asp-for="Quantity" placeholder="1" />
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                <i class="bi bi-check-lg me-2"></i>Aplicar Alterações
                            </button>
                            <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>