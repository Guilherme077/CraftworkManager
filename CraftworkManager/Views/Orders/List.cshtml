@{
    ViewData["Title"] = "Pedidos";
}

@model List<CraftworkManager.Models.Order>

<h1>Pedidos</h1>
<a asp-controller="Orders" asp-action="Add" class="btn btn-primary">Novo Pedido</a>


<table class="table">
    <thead>
        <tr>
            <th>Descrição</th>
            <th>Data do Pedido</th>
            <th>Prazo</th>
            <th>Status</th>
            <th>Cliente</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.getSmallDescription()</td>
                <td>@order.CreatedOn</td>
                <td>@order.DeadlineOn</td>
                <td>@order.Status</td>
                <td>@order.ClientName</td>
                <td><a class="btn btn-primary" asp-controller="Orders" asp-action="Edit" asp-route-id="@order.Id">Visualizar</a></td>
            </tr>
        }
    </tbody>
</table>
