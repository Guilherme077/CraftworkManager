@{
}

@model CraftworkManager.Models.Product

@if (Model is null)
{
    <p class="alert-warning">Produto não encontrado. O produto pode ter sido excluido ou você não possui acesso.</p>
}
else
{
    <form method="post">

        <h1>Editar Produto</h1>

        <div class="mt-3">
            <label class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Name" />
        </div>

        <div class="mt-3">
            <label class="form-label">Descrição</label>
            <input type="text" class="form-control" asp-for="Description" />
        </div>

        <div class="mt-3">
            <label class="form-label">Custo de Produção Padrão</label>
            <input type="number" step="0.01" class="form-control" asp-for="StandardCost" />
        </div>

        <div class="mt-3">
            <label class="form-label">Preço de Venda Padrão</label>
            <input type="number" step="0.01" class="form-control" asp-for="StandardPrice" />
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
        </div>

    </form>
}

